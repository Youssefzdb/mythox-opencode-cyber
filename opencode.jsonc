{
  "$schema": "https://opencode.ai/config.json",

  // ══════════════════════════════════════════════════════
  //   MYTHOX CYBER OPS — OpenCode Configuration
  //   6 Specialized Agents | 3 Free Models | Zero Cost
  // ══════════════════════════════════════════════════════

  // النموذج الافتراضي للـ primary agents
  "model": "openai/north-mini-code-free",

  // ── Provider: OpenCode Zen (100% Free) ──────────────
  "provider": {
    "openai": {
      "name": "OpenCode Zen",
      "baseURL": "https://opencode.ai/zen/v1",
      "models": {

        // ⚡ الأسرع — للبناء والأوامر السريعة
        "north-mini-code-free": {
          "name": "North Mini Code ⚡",
          "attachment": false,
          "reasoning": false,
          "temperature": 0.2,
          "cost": { "input": 0, "output": 0 }
        },

        // 🧠 الأقوى — للتحليل العميق والـ reasoning
        "mimo-v2.5-free": {
          "name": "MiMo V2.5 🧠",
          "attachment": false,
          "reasoning": true,
          "temperature": 0.1,
          "cost": { "input": 0, "output": 0 }
        },

        // 🔬 للتحليل العلمي والـ forensics
        "nemotron-3-ultra-free": {
          "name": "Nemotron Ultra 🔬",
          "attachment": false,
          "reasoning": false,
          "temperature": 0.1,
          "cost": { "input": 0, "output": 0 }
        },

        // 🚀 للتقارير والكتابة
        "deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash 🚀",
          "attachment": false,
          "reasoning": false,
          "temperature": 0.3,
          "cost": { "input": 0, "output": 0 }
        },

        // 🥒 backup عام
        "big-pickle": {
          "name": "Big Pickle 🥒",
          "attachment": false,
          "reasoning": false,
          "temperature": 0.2,
          "cost": { "input": 0, "output": 0 }
        }
      }
    }
  },

  // ── Agents Configuration ─────────────────────────────
  "agent": {

    // المدمج الافتراضي — نحسّنه للـ cybersecurity
    "build": {
      "mode": "primary",
      "model": "openai/north-mini-code-free",
      "temperature": 0.2,
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "read": "allow",
        "write": "allow"
      }
    },

    // Plan agent — للمراجعة بدون تعديل
    "plan": {
      "mode": "primary",
      "model": "openai/mimo-v2.5-free",
      "temperature": 0.1,
      "permission": {
        "bash": "ask",
        "edit": "deny",
        "write": "deny"
      }
    }
  },

  // ── Permissions ──────────────────────────────────────
  "permission": {
    "bash": {
      "*": "allow"
    },
    "read": {
      "*": "allow"
    },
    "write": {
      "*": "allow"
    },
    "edit": {
      "*": "allow"
    }
  },

  // ── TUI Settings ─────────────────────────────────────
  "theme": "opencode",

  // ── Server (Web UI) ──────────────────────────────────
  "server": {
    "port": 4096,
    "hostname": "127.0.0.1"
  },

  // ── Memory / Compaction ──────────────────────────────
  "compaction": {
    "enabled": true,
    "keepLastN": 30
  },

  "autoupdate": true
}
