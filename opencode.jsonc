{
  "$schema": "https://opencode.ai/config.json",

  // ══════════════════════════════════════════════════════
  //   MYTHOX CYBER OPS — OpenCode Configuration
  //   6 Specialized Agents | Free Models via OpenCode Zen
  // ══════════════════════════════════════════════════════

  // النموذج الافتراضي
  "model": "zen/north-mini-code-free",

  // ── Provider: OpenCode Zen (مجاني 100%) ──────────────
  // لا يحتاج API key — فقط: opencode auth login → اختر Zen
  "provider": {
    "zen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Zen 🆓",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1"
      },
      "models": {
        "north-mini-code-free": {
          "name": "North Mini Code ⚡"
        },
        "mimo-v2.5-free": {
          "name": "MiMo V2.5 🧠",
          "reasoning": true
        },
        "nemotron-3-ultra-free": {
          "name": "Nemotron Ultra 🔬"
        },
        "deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash 🚀"
        },
        "big-pickle": {
          "name": "Big Pickle 🥒"
        }
      }
    }
  },

  // ── Permissions (allow all for pentest work) ──────────
  "permission": {
    "bash": {
      "*": "allow"
    },
    "read": {
      "*": "allow"
    },
    "write": {
      "*": "allow"
    },
    "edit": {
      "*": "allow"
    }
  },

  // ── Theme ─────────────────────────────────────────────
  "theme": "opencode",

  "autoupdate": true
}
